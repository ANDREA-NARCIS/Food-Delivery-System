<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="foodPU">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.food.entity.User</class>
        <class>com.food.entity.Restaurant</class>
        <class>com.food.entity.Order</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/food_delivery"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="root123"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <!-- Auto table creation -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Show SQL -->
            <property name="hibernate.show_sql" value="true"/>
        </properties>

    </persistence-unit>
</persistence>